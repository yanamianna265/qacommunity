<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.qacommunity.mapper.QuestionHotMapper">

    <resultMap id="ResultMap" type="QuestionHot">
        <id column="question_id" property="questionId"/>
        <result column="hot_score" property="hotScore"/>
        <result column="answer_count" property="answerCount"/>
        <result column="view_count" property="viewCount"/>
        <result column="last_update_time" property="lastUpdateTime"/>
    </resultMap>

    <resultMap id="HotQuestionVOMap" type="HotQuestionVO">
        <id column="question_id" property="questionId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="tag" property="tag"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="created_at" property="createdAt"/>
        <result column="hot_score" property="hotScore"/>
        <result column="answer_count" property="answerCount"/>
    </resultMap>

    <insert id="insertOrUpdate" parameterType="map">
        INSERT INTO question_hot (question_id, hot_score, answer_count, view_count, last_update_time)
        VALUES (#{questionId}, #{hotScore}, #{answerCount}, #{viewCount}, UNIX_TIMESTAMP() * 1000)
        ON DUPLICATE KEY UPDATE
            hot_score = #{hotScore},
            answer_count = #{answerCount},
            view_count = #{viewCount},
            last_update_time = UNIX_TIMESTAMP() * 1000
    </insert>

    <select id="selectHotList" resultMap="HotQuestionVOMap">
        SELECT q.question_id, q.title, q.content, q.tag, q.user_id, u.username, 
               q.created_at, h.hot_score, h.answer_count
        FROM question_hot h
        LEFT JOIN question q ON h.question_id = q.question_id
        LEFT JOIN user u ON q.user_id = u.user_id
        ORDER BY h.hot_score DESC
        LIMIT #{limit}
    </select>

    <select id="selectByQuestionId" resultMap="ResultMap">
        SELECT * FROM question_hot WHERE question_id = #{questionId}
    </select>

    <delete id="deleteByQuestionId">
        DELETE FROM question_hot WHERE question_id = #{questionId}
    </delete>

</mapper>
