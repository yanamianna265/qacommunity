<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.qacommunity.mapper.QuestionMapper">

    <resultMap id="BaseResultMap" type="Question">
        <id column="question_id" property="questionId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="tag" property="tag"/>
        <result column="user_id" property="userId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <resultMap id="VOResultMap" type="QuestionVO">
        <id column="question_id" property="questionId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="tag" property="tag"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="Question" useGeneratedKeys="true" keyProperty="questionId">
        INSERT INTO question (title, content, tag, user_id, created_at)
        VALUES (#{title}, #{content}, #{tag}, #{userId}, #{createdAt})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM question WHERE question_id = #{questionId}
    </select>

    <select id="selectList" resultMap="VOResultMap">
        SELECT q.question_id, q.title, q.content, q.tag, q.user_id, u.username, q.created_at
        FROM question q
        LEFT JOIN user u ON q.user_id = u.user_id
        ORDER BY q.created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM question
    </select>

    <select id="selectByTag" resultMap="VOResultMap">
        SELECT q.question_id, q.title, q.content, q.tag, q.user_id, u.username, q.created_at
        FROM question q
        LEFT JOIN user u ON q.user_id = u.user_id
        WHERE q.tag = #{tag}
        ORDER BY q.created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByTag" resultType="long">
        SELECT COUNT(*) FROM question WHERE tag = #{tag}
    </select>

</mapper>
